# BFFの環境変数テンプレート。`cp .env.example .env` して設定する(.envはコミットしない)

# Snowflakeアカウントの完全なURL(例: https://<account_identifier>.snowflakecomputing.com)
SNOWFLAKE_ACCOUNT_URL=

# Programmatic Access Token(発行手順は .claude/skills/snowflake-agents/setup.md 参照)
SNOWFLAKE_PAT=

# 呼び出すエージェント(snowflake/ のSQLで作成した識別子に合わせる)
SNOWFLAKE_AGENT_DATABASE=AGENT_DEMO_DB
SNOWFLAKE_AGENT_SCHEMA=AGENTS
SNOWFLAKE_AGENT_NAME=MASTER_AGENT

# CORSで許可するオリジン(JSON配列形式)
# CORS_ORIGINS=["http://localhost:5173"]
